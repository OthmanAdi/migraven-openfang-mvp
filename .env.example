# Azure Foundry deployment endpoints (no keys here, keys come from Windows Credential Manager)
AZURE_FOUNDRY_ENDPOINT=https://YOUR-FOUNDRY.cognitiveservices.azure.com
AZURE_FOUNDRY_GPT55_DEPLOYMENT=gpt-5.5
AZURE_FOUNDRY_OPUS_DEPLOYMENT=claude-opus-4-5

# Neo4j (creds come from Windows Credential Manager target migRaven.MAX-Neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_DATABASE=neo4j

# Credential Store prefix (matches sibling project)
MAX_CREDENTIAL_PREFIX=migRaven.MAX

# Tool limits (override defaults if needed)
CYPHER_TIMEOUT_MS=15000
MAX_ROWS=500
MAX_CHARS=120000
MAX_PARALLEL_QUERIES=5

# OpenFang
OPENFANG_LISTEN=127.0.0.1:50051
